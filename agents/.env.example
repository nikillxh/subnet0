# Copy real secrets to _local/.env (gitignored). This file is a committed template.

# RPC endpoint (local Anvil or Monad testnet)
RPC_URL=http://127.0.0.1:8545
# RPC_URL=https://testnet-rpc.monad.xyz

# Deployed Subnet0 address (or rely on contracts/deployment.json)
# SUBNET0_ADDRESS=0x...

# Comma-separated private keys for the 8-agent fleet.
# Omit to use built-in Anvil dev keys (LOCAL ONLY - never on a real network).
# AGENT_KEYS=0xkey0,0xkey1,...,0xkey7

# OpenAI (optional). Omit to run with the deterministic mock LLM.
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
