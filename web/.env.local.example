# Copy to .env.local. Set SUBNET0_ADDRESS to the address printed by
# `python run_demo.py deploy` (also saved in contracts/deployment.json).

# Local Anvil demo:
NEXT_PUBLIC_RPC_URL=http://127.0.0.1:8545
NEXT_PUBLIC_SUBNET0_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3
NEXT_PUBLIC_CHAIN_ID=31337

# Monad testnet:
# NEXT_PUBLIC_RPC_URL=https://testnet-rpc.monad.xyz
# NEXT_PUBLIC_SUBNET0_ADDRESS=0xYourDeployedAddress
# NEXT_PUBLIC_CHAIN_ID=10143
